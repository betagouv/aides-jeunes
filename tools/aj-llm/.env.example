# ── LLM ──────────────────────────────────────────────────────────────────────
# API compatible OpenAI
OPENAI_API_BASE=https://ia.social.gouv.fr/api/v1
OPENAI_API_KEY=your-key-here
MODEL_NAME="openai/gpt-oss-120b"

# Providers cloud (optionnel — utilisés si MODEL_NAME contient gemini/mistral/grok)
# MISTRAL_API_KEY=
# GOOGLE_API_KEY=

# ── Données Aides Jeunes ─────────────────────────────────────────────────────
# Défaut auto = ../../data (le data/ du repo aides-jeunes qui contient cet outil).
# AIDES_JEUNES_DATA_PATH="/chemin/absolu/vers/aides-jeunes/data"

# ── Mode publication ─────────────────────────────────────────────────────────
# dev  = écrit directement dans data/ (pas de PR) — défaut
# prod = ouvre une PR GitHub (legacy)
PUBLISH_MODE=dev
GITHUB_TOKEN=
GITHUB_OWNER=betagouv
GITHUB_REPO=aides-jeunes

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TTL=3600

# ── Agent ────────────────────────────────────────────────────────────────────
MAX_TOKENS=4096
